// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client-js"
  moduleFormat = "commonjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  templates Template[]
  documents Document[]

  @@map("users")
}

model Template {
  id         String   @id @default(uuid())
  name       String
  userId     String
  content    String
  variables  Json?
  pdfOptions Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id])
  documents Document[]

  @@map("templates")
}

model Document {
  id         String   @id @default(uuid())
  templateId String
  userId     String
  content    String
  values     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  template Template @relation(fields: [templateId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@map("documents")
}
